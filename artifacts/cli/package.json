{
  "name": "@nexushosting/cli",
  "version": "0.1.0",
  "description": "NexusHosting CLI — deploy static sites to your Nexus Hosting node",
  "type": "module",
  "license": "MIT",
  "author": "The No Hands Company <dev@nohands.company>",
  "homepage": "https://github.com/The-No-Hands-company/Nexus-Hosting",
  "repository": {
    "type": "git",
    "url": "https://github.com/The-No-Hands-company/Nexus-Hosting.git",
    "directory": "artifacts/cli"
  },
  "bugs": {
    "url": "https://github.com/The-No-Hands-company/Nexus-Hosting/issues"
  },
  "keywords": [
    "nexushosting",
    "federated",
    "hosting",
    "deploy",
    "static-site",
    "cli"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "nh": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.js --banner:js='#!/usr/bin/env node'",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "conf": "^13.1.0",
    "form-data": "^4.0.2",
    "glob": "^11.0.1",
    "mime-types": "^3.0.1",
    "node-fetch": "^3.3.2",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/mime-types": "^2.1.4",
    "@types/node": "catalog:",
    "esbuild": "^0.27.3",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
